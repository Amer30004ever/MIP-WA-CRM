// MaVoid WhatsApp CRM — Prisma Schema
// Generated: Phase 1 Scaffold & Core CRM Expansion

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  name         String
  role         Role     @default(AGENT)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  conversations Conversation[]
  leads         Lead[]
  deals         Deal[]
  tasks         Task[]
  notes         Note[]
  crmLogs       CrmLog[]

  @@map("users")
}

enum Role {
  ADMIN
  AGENT
}

// ─────────────────────────────────────────────
// WHATSAPP CONTACTS
// ─────────────────────────────────────────────
model WhatsAppContact {
  id          String   @id @default(uuid())
  phone       String   @unique   // e.g. "+966501234567"
  name        String?
  profilePic  String?
  isBlocked   Boolean  @default(false)
  tags        String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  conversations Conversation[]
  contact       Contact?
  leads         Lead[]

  @@map("whatsapp_contacts")
}

// ─────────────────────────────────────────────
// CONVERSATIONS
// ─────────────────────────────────────────────
model Conversation {
  id          String             @id @default(uuid())
  status      ConversationStatus @default(OPEN)
  assignedTo  User?              @relation(fields: [assignedToId], references: [id])
  assignedToId String?
  contact     WhatsAppContact    @relation(fields: [contactId], references: [id])
  contactId   String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  unreadCount        Int                @default(0)
  lastMessageAt      DateTime           @default(now())
  lastMessagePreview String?

  messages    Message[]
  tasks       Task[]

  @@map("conversations")
}

enum ConversationStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

// ─────────────────────────────────────────────
// MESSAGES
// ─────────────────────────────────────────────
model Message {
  id             String      @id @default(uuid())
  waMessageId    String?     @unique  // WhatsApp message ID
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId String
  direction      Direction
  type           MessageType @default(TEXT)
  content        String
  mediaUrl       String?
  timestamp      DateTime    @default(now())
  isRead         Boolean     @default(false)

  @@map("messages")
}

enum Direction {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  TEMPLATE
}

// ─────────────────────────────────────────────
// WEBHOOK LOGS
// ─────────────────────────────────────────────
model WebhookLog {
  id          String   @id @default(uuid())
  source      String   @default("whatsapp")
  payload     Json
  processed   Boolean  @default(false)
  error       String?
  receivedAt  DateTime @default(now())

  @@map("webhook_logs")
}

// ─────────────────────────────────────────────
// COMPANIES
// ─────────────────────────────────────────────
model Company {
  id        String   @id @default(uuid())
  name      String
  domain    String?
  industry  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts Contact[]
  deals    Deal[]
  notes    Note[]

  @@map("companies")
}

// ─────────────────────────────────────────────
// CRM CONTACTS
// ─────────────────────────────────────────────
model Contact {
  id               String           @id @default(uuid())
  name             String
  email            String?
  phone            String?
  jobTitle         String?
  companyId        String?
  company          Company?         @relation(fields: [companyId], references: [id])
  whatsAppContactId String?         @unique
  whatsAppContact  WhatsAppContact? @relation(fields: [whatsAppContactId], references: [id])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  deals Deal[]
  notes Note[]

  @@map("contacts")
}

// ─────────────────────────────────────────────
// LEADS
// ─────────────────────────────────────────────
model Lead {
  id                String           @id @default(uuid())
  title             String
  status            LeadStatus       @default(NEW)
  value             Float?
  whatsAppContactId String?
  whatsAppContact   WhatsAppContact? @relation(fields: [whatsAppContactId], references: [id])
  assignedToId      String?
  assignedTo        User?            @relation(fields: [assignedToId], references: [id])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  tasks Task[]
  notes Note[]

  @@map("leads")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  LOST
}

// ─────────────────────────────────────────────
// DEALS
// ─────────────────────────────────────────────
model Deal {
  id           String    @id @default(uuid())
  title        String
  value        Float
  stage        DealStage @default(NEW)
  companyId    String?
  company      Company?  @relation(fields: [companyId], references: [id])
  contactId    String?
  contact      Contact?  @relation(fields: [contactId], references: [id])
  assignedToId String?
  assignedTo   User?     @relation(fields: [assignedToId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tasks Task[]
  notes Note[]

  @@map("deals")
}

enum DealStage {
  NEW
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

// ─────────────────────────────────────────────
// TASKS
// ─────────────────────────────────────────────
model Task {
  id             String       @id @default(uuid())
  title          String
  description    String?
  dueDate        DateTime?
  status         TaskStatus   @default(TODO)
  assignedToId   String?
  assignedTo     User?        @relation(fields: [assignedToId], references: [id])
  leadId         String?
  lead           Lead?        @relation(fields: [leadId], references: [id])
  dealId         String?
  deal           Deal?        @relation(fields: [dealId], references: [id])
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("tasks")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

// ─────────────────────────────────────────────
// NOTES
// ─────────────────────────────────────────────
model Note {
  id        String   @id @default(uuid())
  content   String
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id])
  dealId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id])
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notes")
}

// ─────────────────────────────────────────────
// CRM AUDIT LOGS
// ─────────────────────────────────────────────
model CrmLog {
  id         String   @id @default(uuid())
  action     String   // e.g. "CREATE", "UPDATE", "DELETE", "STAGE_CHANGE"
  entityType String   // e.g. "LEAD", "DEAL", "TASK", "CONTACT", "COMPANY"
  entityId   String
  details    Json?    // Generic details or JSON payload
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())

  @@map("crm_logs")
}
