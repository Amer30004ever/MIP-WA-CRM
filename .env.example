# ============================================
# MaVoid WhatsApp CRM - Environment Variables
# ============================================

# Node Environment
NODE_ENV=development

# ============================================
# Database Configuration
# ============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mavoid_crm
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/mavoid_crm

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET=your-super-secret-key-at-least-32-characters-long
JWT_EXPIRES_IN=7d

# ============================================
# Application URLs
# ============================================
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# ============================================
# WhatsApp Business Platform Configuration
# ============================================
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_WABA_ID=your_waba_id_here
WHATSAPP_VERIFY_TOKEN=your_verify_token_here
WEBHOOK_SECRET=your_webhook_secret_here